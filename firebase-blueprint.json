{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "product_manager", "manager", "editor"] },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "promoUsage": { "type": "object" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Game or digital product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "priceRange": { "type": "object" },
        "category": { "type": "string" },
        "genre": { "type": "string" },
        "platform": { "type": "string" },
        "publisher": { "type": "string" },
        "releaseDate": { "type": "string" },
        "popularity": { "type": "number" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "featured": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "discountPrice": { "type": "number" },
        "warranty": { "type": "string" },
        "versions": { "type": "array" }
      },
      "required": ["name", "price", "category"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "Discount promo code",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minPurchase": { "type": "number" },
        "expiryDate": { "type": "string" },
        "active": { "type": "boolean" },
        "usageLimitPerUser": { "type": "integer" }
      },
      "required": ["code", "type", "value", "active"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "discountAmount": { "type": "number" },
        "promoCode": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["bkash", "nagad"] },
        "paymentNumber": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled", "cancellation_requested", "cancellation_approved", "cancellation_rejected"] },
        "statusLog": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "cancellationReason": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "paymentMethod", "paymentNumber", "status"]
    },
    "SiteContent": {
      "title": "SiteContent",
      "description": "General site content like Contact Us and Refund Policy",
      "type": "object",
      "properties": {
        "contactUs": { "type": "string" },
        "refundPolicy": { "type": "string" },
        "privacyPolicy": { "type": "string" },
        "termsOfService": { "type": "string" },
        "faq": { "type": "string" },
        "paymentInstructions": { "type": "string" }
      },
      "required": ["contactUs", "refundPolicy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available products"
    },
    "/promoCodes/{promoId}": {
      "schema": "PromoCode",
      "description": "Promo codes"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/settings/siteContent": {
      "schema": "SiteContent",
      "description": "Global site content settings"
    }
  }
}
