rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - email: string (required) - User's email address
    //   - displayName: string (optional) - User's display name
    //   - photoURL: string (optional) - User's profile photo URL
    //   - role: string (required, enum: ['user', 'admin']) - User's role
    //   - wishlist: list (optional) - List of product IDs
    //   - createdAt: string (required, ISO 8601) - Account creation date
    //
    // Collection: products
    // Document ID: {productId} (Auto-generated)
    // Fields:
    //   - id: string (required) - Product ID
    //   - name: string (required) - Product name
    //   - description: string (required) - Product description
    //   - price: number (required) - Product price in BDT
    //   - category: string (required) - Product category
    //   - genre: string (required) - Game genre
    //   - platform: string (required) - Gaming platform
    //   - publisher: string (required) - Game publisher
    //   - releaseDate: string (required) - Release date
    //   - popularity: number (required) - Popularity score
    //   - imageUrl: string (required) - Product image URL
    //   - stock: number (required) - Available stock
    //   - featured: boolean (optional) - Whether the product is featured
    //
    // Collection: orders
    // Document ID: {orderId} (Auto-generated)
    // Fields:
    //   - id: string (required) - Order ID
    //   - userId: string (required) - ID of the user who placed the order
    //   - items: list (required) - List of ordered items
    //   - totalAmount: number (required) - Total order amount
    //   - paymentMethod: string (required, enum: ['bkash', 'nagad']) - Payment method
    //   - paymentNumber: string (required) - Sender's payment number
    //   - transactionId: string (required) - Payment transaction ID
    //   - status: string (required, enum: ['pending', 'completed', 'cancelled']) - Order status
    //   - createdAt: string (required, ISO 8601) - Order creation date
    //
    // Collection: reviews
    // Document ID: {reviewId} (Auto-generated)
    // Fields:
    //   - id: string (required)
    //   - productId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - userPhoto: string (optional)
    //   - rating: number (required, 1-5)
    //   - comment: string (required)
    //   - createdAt: string (required, ISO 8601)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() in ['super_admin', 'admin', 'manager', 'product_manager', 'editor', 'content_manager', 'sales_manager']) ||
         (request.auth.token.email == "chadmulla7@gmail.com"));
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'admin') ||
         (request.auth.token.email == "chadmulla7@gmail.com"));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['user', 'super_admin', 'admin', 'manager', 'product_manager', 'editor', 'content_manager', 'sales_manager'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('wishlist' in data) || data.wishlist is list) &&
             (!('promoUsage' in data) || data.promoUsage is map);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'genre', 'platform', 'publisher', 'releaseDate', 'popularity', 'stock']) &&
             data.name is string && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.category is string && data.category.size() < 100 &&
             data.genre is string && data.genre.size() < 100 &&
             data.platform is string && data.platform.size() < 100 &&
             data.publisher is string && data.publisher.size() < 100 &&
             data.releaseDate is string &&
             data.popularity is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('reviewsCount' in data) || (data.reviewsCount is number)) &&
             (!('discountPrice' in data) || (data.discountPrice is number && data.discountPrice >= 0)) &&
             (!('warranty' in data) || (data.warranty is string)) &&
             (!('versions' in data) || (data.versions is list)) &&
             (!('priceRange' in data) || (data.priceRange is map)) &&
             (!('featured' in data) || (data.featured is bool));
    }

    function isValidPromoCode(data) {
      return data.keys().hasAll(['code', 'type', 'value', 'active']) &&
             data.code is string && data.code.size() < 50 &&
             data.type in ['percentage', 'fixed'] &&
             data.value is number && data.value > 0 &&
             data.active is bool &&
             (!('minPurchase' in data) || (data.minPurchase is number)) &&
             (!('expiryDate' in data) || (data.expiryDate is string)) &&
             (!('usageLimitPerUser' in data) || (data.usageLimitPerUser is number));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.productId is string &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.createdAt is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'paymentMethod', 'paymentNumber', 'status', 'transactionId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.paymentMethod in ['bkash', 'nagad'] &&
             data.status in ['pending', 'completed', 'cancelled', 'cancellation_requested', 'cancellation_approved', 'cancellation_rejected'] &&
             data.transactionId is string && data.transactionId.size() >= 8 && data.transactionId.size() <= 50 &&
             data.paymentNumber is string && data.paymentNumber.matches('^01[3-9]\\d{8}$') &&
             data.createdAt is string &&
             data.items is list &&
             (!('userName' in data) || data.userName is string) &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('userPhone' in data) || data.userPhone is string) &&
             (!('cancellationReason' in data) || data.cancellationReason is string) &&
             (!('cancellationRejectionReason' in data) || data.cancellationRejectionReason is string) &&
             (!('discountAmount' in data) || data.discountAmount is number) &&
             (!('promoCode' in data) || data.promoCode is string || data.promoCode == null) &&
             (!('statusLog' in data) || data.statusLog is list);
    }

    function isValidSiteContent(data) {
      return data.keys().hasAll(['contactUs', 'refundPolicy']) &&
             data.contactUs is string && data.contactUs.size() < 5000 &&
             data.refundPolicy is string && data.refundPolicy.size() < 10000 &&
             (!('privacyPolicy' in data) || (data.privacyPolicy is string && data.privacyPolicy.size() < 10000)) &&
             (!('termsOfService' in data) || (data.termsOfService is string && data.termsOfService.size() < 10000)) &&
             (!('faq' in data) || (data.faq is string && data.faq.size() < 10000)) &&
             (!('paymentInstructions' in data) || (data.paymentInstructions is string && data.paymentInstructions.size() < 5000));
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isSuperAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if (isAdmin() && isValidProduct(request.resource.data)) || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewsCount', 'stock', 'versions']));
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidReview(request.resource.data);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && request.resource.data.status in ['cancelled', 'cancellation_requested'] && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /promoCodes/{promoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPromoCode(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }

    match /settings/siteContent {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteContent(request.resource.data);
    }
  }
}
