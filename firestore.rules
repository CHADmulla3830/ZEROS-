rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "chadmulla7@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'genre', 'platform', 'publisher', 'releaseDate', 'popularity']) &&
             data.name is string && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.genre is string &&
             data.platform is string &&
             data.publisher is string &&
             data.releaseDate is string &&
             data.popularity is number;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'paymentMethod', 'paymentNumber', 'status', 'transactionId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.totalAmount is number && data.totalAmount > 0 &&
             data.paymentMethod in ['bkash', 'nagad'] &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.transactionId is string &&
             data.createdAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }
  }
}
